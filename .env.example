# LLM provider — set ISBE_LLM_PROVIDER to anthropic (default) or deepseek
ISBE_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Postgres
POSTGRES_USER=isbe
POSTGRES_PASSWORD=changeme
POSTGRES_DB=isbe

# Prefect
PREFECT_API_URL=http://localhost:4200/api

# Phoenix (LLM trace) — 零登录，UI 在 http://localhost:6006。
# 留空则 trace 静默 no-op；要打开 trace，host 跑 worker 用 localhost，docker worker 用 phoenix:6006。
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_PROJECT_NAME=isbe

# MinIO
MINIO_ROOT_USER=isbe
MINIO_ROOT_PASSWORD=changeme123

# GitHub API token (optional) — empty = 60 req/hr; set = 5000 req/hr
# Create at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Single-user default
ISBE_UID=me
