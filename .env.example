# LLM provider — set ISBE_LLM_PROVIDER to anthropic (default) or deepseek
ISBE_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Postgres
POSTGRES_USER=isbe
POSTGRES_PASSWORD=changeme
POSTGRES_DB=isbe

# Prefect
PREFECT_API_URL=http://localhost:4200/api

# Langfuse (LLM trace) — 在 http://localhost:3000 创建项目并取 keys 后填入；空值时 trace 静默 no-op
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_NEXTAUTH_SECRET=changeme-32chars-changeme-32chars
LANGFUSE_SALT=changeme-salt-changeme-salt

# MinIO
MINIO_ROOT_USER=isbe
MINIO_ROOT_PASSWORD=changeme123

# GitHub API token (optional) — empty = 60 req/hr; set = 5000 req/hr
# Create at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Single-user default
ISBE_UID=me
